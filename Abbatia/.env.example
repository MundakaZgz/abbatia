# App
APP_PORT=8080
MANAGER_USER=admin
MANAGER_PASSWORD=admin

# DB connection used by app (JNDI jdbc/Abadias)
DB_HOST=db
DB_PORT=3306
DB_NAME=abbatia
DB_USER=abbatia_inet
DB_PASSWORD=change_me

# Optional separate credentials for background/process datasource (JNDI jdbc/Procesos)
DB_PROCESS_USER=abbatia_inet
DB_PROCESS_PASSWORD=change_me

# MySQL root password for container bootstrap
MYSQL_ROOT_PASSWORD=root_change_me

# Host exposed DB port
DB_EXPOSED_PORT=3306

# Local registration and mail behavior
ABBATIA_AUTO_APPROVE_REGISTRATION=true

# Mail sender settings (defaults target local MailHog)
MAIL_FROM=noreply@abbatia.local
MAIL_SMTP_HOST=mailhog
MAIL_SMTP_PORT=1025
MAIL_SMTP_AUTH=false
MAIL_SMTP_SSL=false
MAIL_SMTP_STARTTLS=false
MAIL_SMTP_USER=
MAIL_SMTP_PASS=
MAIL_DEBUG=false

# MailHog UI exposed port
MAILHOG_UI_PORT=8025
